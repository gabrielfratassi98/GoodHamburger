@page "/menu"
@using Radzen
@using Radzen.Blazor
@inject MessageService MsgService
@inject IMenuService _menuService
@inject IOrderService _orderService
@inject NavigationManager NavigationManager

<PageTitle>Menu</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" class="rz-mb-6">
    <RadzenSelectBar @bind-Value="@categoriaSelecionada" TValue="string" Size="ButtonSize.Medium">
        <Items>
            <RadzenSelectBarItem Text="All" Value="@("All")" />
            <RadzenSelectBarItem Text="Sandwiches" Value="@("Sandwiches")" />
            <RadzenSelectBarItem Text="Extras" Value="@("Extras")" />
        </Items>
    </RadzenSelectBar>
</RadzenStack>

@if (orderId > 0)
{
    <RadzenRow Gap="1rem" class="rz-p-4">
        <RadzenColumn Size="3">
            <RadzenButton Text="Go To Cart" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Large" Click="() => GoToCart()" Class="rz-w-100" />
        </RadzenColumn>
    </RadzenRow>
}

<RadzenRow Gap="1rem" class="rz-p-4">
    @foreach (var product in filteredProducts)
    {
        <RadzenColumn Size="12" SizeMD="6" SizeLG="4" SizeXL="3">
            <RadzenCard Style="height: 100%; display: flex; flex-direction: column; justify-content: space-between; padding: 1rem;">

                <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenImage Path="@product.ImageUrl" Style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover;" />
                    <RadzenText TextStyle="TextStyle.H6" class="rz-text-center">@product.Name</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-gray-600 rz-text-center" Style="height: 60px;">
                        @product.Description
                    </RadzenText>
                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mt-4">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">
                        $@product.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
                    </RadzenText>
                    <RadzenButton Icon="add_shopping_cart"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="@(() => AddToCart(product.Id))"
                                  Text="Add To Cart" />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    }
</RadzenRow>

@code {
    long orderId = 0;
    string categoriaSelecionada = "All";

    List<Product> allProducts = new();

    protected override async Task OnInitializedAsync()
    {
        await InitMenu();
    }

    async Task InitMenu()
    {
        ApiResponse<MenuData> menuModel = await _menuService.GetMenu();
        ApiResponse<IEnumerable<OrderModel>> orders = await _orderService.GetAllOrders();
        
        OrderModel order = orders?.Data?.FirstOrDefault(o => o.Active) ?? new OrderModel();

        orderId = order?.Id ?? 0;

        allProducts = menuModel.Data.Sandwiches.Concat(menuModel.Data.Extras).ToList();
    }

    IEnumerable<Product> filteredProducts => categoriaSelecionada == "All"
    ? allProducts
    : allProducts.Where(p =>
        (categoriaSelecionada == "Sandwiches" && p.Category == 1) ||
        (categoriaSelecionada == "Extras" && (p.Category == 2 || p.Category == 3)));

    async Task AddToCart(int idProduct)
    {
        ApiResponse<OrderModel> response = await _orderService.AddProductOrder(idProduct, orderId);

        if (response == null || !response.Success)
        {
            MsgService.ShowMessage(response.Message, isError: true);
            return;
        }

        OrderModel order = response.Data;

        if (order != null)
        {
            orderId = order.Id;
        }

        MsgService.ShowMessage(response.Message);
    }

    async Task DeleteProduct(int idProduct)
    {
        ApiResponse<OrderModel> response = await _orderService.DeleteProductOrder(idProduct, orderId);

        if (!response.Success)
        {
            MsgService.ShowMessage(response.Message, isError: true);
            return;
        }

        MsgService.ShowMessage(response.Message);
    }

    async Task GoToCart()
    {
        NavigationManager.NavigateTo("/cart");
    }
}
